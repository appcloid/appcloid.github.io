# AppCloid EmailJS Configuration
# Do not commit the actual .env.local file to version control.
# Create an EmailJS account, setup an email service and template, and copy the keys here.

NEXT_PUBLIC_EMAILJS_SERVICE_ID="your_service_id_here"
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID="your_template_id_here"
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY="your_public_key_here"
